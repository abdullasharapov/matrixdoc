# PostgreSQL
POSTGRES_USER=synapse
POSTGRES_PASSWORD=change_me_db_password
POSTGRES_DB=synapse
POSTGRES_INITDB_ARGS=--encoding=UTF-8 --lc-collate=C --lc-ctype=C

# Synapse
SYNAPSE_DOMAIN=talks.example.com
SYNAPSE_REPORT_STATS=false
SYNAPSE_PUBLIC_BASEURL=https://talks.example.com/
TRUSTED_KEY_SERVER=matrix.org
ENABLE_3PID_CHANGES=true
ENABLE_REGISTRATION=false
ENABLE_METRICS=true
MAX_UPLOAD_SIZE=100M
MAX_IMAGE_PIXELS=64M
MAX_EVENT_DELAY_DURATION=24h
RC_MESSAGE_PER_SECOND=0.5
RC_MESSAGE_BURST_COUNT=30
RC_DELAYED_EVENT_MGMT_PER_SECOND=1
RC_DELAYED_EVENT_MGMT_BURST_COUNT=20
MSC3266_ENABLED=true
MSC4222_ENABLED=true
MSC4140_ENABLED=true

# SMTP
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=mailer@example.com
SMTP_PASS=change_me_smtp_password
SMTP_FROM=Synapse server
SMTP_ENABLE_NOTIFS=true
SMTP_VALIDATION_TOKEN_LIFETIME=15m

